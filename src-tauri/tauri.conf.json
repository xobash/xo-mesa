{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mesa",
  "version": "0.1.0",
  "identifier": "dev.xo.mesa",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Mesa",
        "label": "main",
        "width": 1680,
        "height": 1050,
        "minWidth": 1000,
        "minHeight": 640,
        "maximized": true,
        "dragDropEnabled": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
